{
  "name": "alpha-factor-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AlphaFactorForge — Automated Indicator Discovery Workstation",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures:indicators": "vite-node scripts/generate-indicator-fixtures.ts",
    "fixtures:backtest": "vite-node scripts/generate-backtest-fixtures.ts",
    "fixtures:signals-split": "vite-node scripts/generate-signals-split-fixtures.ts",
    "fixtures:benchmarks": "vite-node scripts/generate-benchmark-fixtures.ts",
    "e2e": "playwright test",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "6.4.3",
    "vite-node": "3.2.4",
    "vitest": "3.2.6"
  }
}
